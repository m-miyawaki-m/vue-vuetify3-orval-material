{
  "name": "vuetify-project",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "test": "vitest",
    "test:run": "vitest run --reporter=verbose",
    "test:report": "vitest run --reporter=html && npx vite preview --outDir html --open --port 4173",
    "test:ui": "vitest --ui --watch",
    "test:coverage": "vitest run --coverage",
    "test:coverage:open": "vitest run --coverage && start coverage/index.html",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report --port 0",
    "test:all": "vitest run --reporter=verbose && playwright test",
    "lint": "eslint . --fix",
    "format": "prettier --write src",
    "orval": "orval",
    "mock:prism": "npx @stoplight/prism-cli mock openapi/api.yaml --port 4010 --cors",
    "dev:mock": "run-p dev mock:prism",
    "build:android-mock": "vite build --mode android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/camera": "^7.0.5",
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "7.4.47",
    "@tanstack/vue-query": "^5.101.0",
    "@zxing/browser": "^0.2.0",
    "axios": "^1.17.0",
    "material-icons": "^1.13.14",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.30",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "orval": "^8.15.0",
    "prettier": "^3.8.4",
    "sass": "^1.100.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.1",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
