{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev:browser",
      "type": "shell",
      "command": "npm run dev",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": [],
      "detail": "Mode 1: Vite dev server をブラウザで開く"
    },
    {
      "label": "mock:prism",
      "type": "shell",
      "command": "npm run mock:prism",
      "presentation": { "reveal": "always", "panel": "new" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": ".", "file": 1, "location": 2, "message": 3 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Prism is listening"
        }
      },
      "detail": "Prism モックサーバーを起動（port 4010）"
    },
    {
      "label": "dev:mock",
      "dependsOn": ["dev:browser", "mock:prism"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "detail": "Vite dev server + Prism モックサーバーを同時起動（ブラウザ確認用）"
    },
    {
      "label": "emulator:mock",
      "dependsOn": ["mock:prism", "android:livereload"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "detail": "Prism モック + エミュレータ livereload を同時起動（android:livereload が Vite を内包）"
    },
    {
      "label": "build:web",
      "type": "shell",
      "command": "npm run build",
      "problemMatcher": ["$tsc"],
      "detail": "Vite プロダクションビルド"
    },
    {
      "label": "cap:sync",
      "type": "shell",
      "command": "npx cap sync android",
      "dependsOn": "build:web",
      "problemMatcher": [],
      "detail": "ビルド後に Android プロジェクトへ反映"
    },
    {
      "label": "adb:forward",
      "type": "shell",
      "command": "adb forward tcp:9222 localabstract:chrome_devtools_remote",
      "problemMatcher": [],
      "detail": "WebView デバッグ用に ADB ポートフォワードを設定（エミュレータ起動後に実行）"
    },
    {
      "label": "emulator:start",
      "type": "shell",
      "command": "${env:ANDROID_HOME}/emulator/emulator -avd Pixel6_API33",
      "presentation": { "reveal": "always", "panel": "new" },
      "isBackground": true,
      "problemMatcher": [],
      "detail": "AVD を起動（エミュレータ画面が別ウィンドウで開く）"
    },
    {
      "label": "android:livereload",
      "type": "shell",
      "command": "npx cap run android --livereload --external",
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": [],
      "detail": "Mode 2: Vite dev server + APK デプロイ（HMR 有効）"
    },
    {
      "label": "android:build:debug",
      "type": "shell",
      "command": ".\\gradlew.bat assembleDebug",
      "options": { "cwd": "${workspaceFolder}/android" },
      "dependsOn": "cap:sync",
      "problemMatcher": [],
      "detail": "Mode 3: デバッグ APK をビルド"
    },
    {
      "label": "android:install:debug",
      "type": "shell",
      "command": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
      "problemMatcher": [],
      "detail": "Mode 3: 接続中のデバイスに APK をインストール"
    },
    {
      "label": "android:open",
      "type": "shell",
      "command": "npx cap open android",
      "dependsOn": "cap:sync",
      "problemMatcher": [],
      "detail": "Mode 4: Android Studio でリリースビルド・署名・Logcat"
    },

    // ── APK standalone + Prism 連携 ──────────────────────────────────
    {
      "label": "apk-mock:build",
      "type": "shell",
      "command": "npm run build:android-mock",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": [],
      "detail": "[apk-mock] .env.android (10.0.2.2:4010) で Vite ビルド"
    },
    {
      "label": "apk-mock:sync",
      "type": "shell",
      "command": "npx cap sync android",
      "dependsOn": ["apk-mock:build"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": [],
      "detail": "[apk-mock] ビルド成果物を Android プロジェクトへ反映"
    },
    {
      "label": "apk-mock:assemble",
      "type": "shell",
      "command": ".\\gradlew.bat assembleDebug",
      "options": { "cwd": "${workspaceFolder}/android" },
      "dependsOn": ["apk-mock:sync"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": [],
      "detail": "[apk-mock] デバッグ APK をビルド"
    },
    {
      "label": "apk-mock:install",
      "type": "shell",
      "command": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk",
      "dependsOn": ["apk-mock:assemble"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": [],
      "detail": "[apk-mock] エミュレータに APK をインストール"
    },
    {
      "label": "apk-mock:launch",
      "type": "shell",
      "command": "adb shell am start -n com.example.myapp/.MainActivity",
      "dependsOn": ["apk-mock:install"],
      "dependsOrder": "sequence",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": [],
      "detail": "[apk-mock] エミュレータ上でアプリを起動"
    },
    {
      "label": "emulator:apk-mock",
      "dependsOn": ["mock:prism", "apk-mock:launch"],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "detail": "APK standalone + Prism 連携起動（Prism先行 / ビルド→sync→assemble→install→launch）"
    }
  ]
}
